dcode .env
# ─── Base de datos ────────────────────────────────────────────────────────────
# Ejemplo Railway: postgresql://USER:PASS@containers-us-west-X.railway.app:PORT/railway
DATABASE_URL=postgresql://postgres:EfBbOVsAcNTwdbhqIXurAIQZbjwSPidP@shinkansen.proxy.rlwy.net:49982/railway

# ─── MercadoPago ──────────────────────────────────────────────────────────────
# Obtener en: https://www.mercadopago.com.ar/developers/panel/app
MP_ACCESS_TOKEN="TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
MP_PUBLIC_KEY="TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Clave secreta para validar firma de webhooks (configurar en el panel de MP)
MP_WEBHOOK_SECRET="tu_webhook_secret_aqui"

# ─── Impresora térmica ────────────────────────────────────────────────────────
# IP de la impresora en la red local del restaurante
PRINTER_IP="192.168.1.100"
PRINTER_PORT="9100"

# ─── Panel de administración ──────────────────────────────────────────────────
ADMIN_PASSWORD="admin123"

# ─── URLs de la aplicación ───────────────────────────────────────────────────
# En desarrollo usar http://localhost:3000
# En producción usar https://tu-dominio.com
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ─── Configuración del negocio ────────────────────────────────────────────────
TIEMPO_ESTIMADO_DELIVERY="45"
TIEMPO_ESTIMADO_RETIRO="20"
RESTAURANTE_NOMBRE="El Restaurante"

# ─── N8N — Notificaciones automáticas ────────────────────────────────────────
# URL del webhook de N8N (dejar vacío para deshabilitar notificaciones)
# Ejemplo: https://tu-n8n.railway.app/webhook/restaurante-eventos
N8N_WEBHOOK_URL=""
